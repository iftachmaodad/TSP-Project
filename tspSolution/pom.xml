<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <groupId>tspSolution</groupId>
    <artifactId>tspSolution</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>TSP Solver</name>
    <description>
        Interactive Travelling Salesman Problem solver with deadline constraints.
        Supports AirCity (Haversine) and GroundCity (OSRM road distances) modes,
        four solver algorithms, and a benchmark tab for algorithm comparison.
    </description>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- Properties                                                            -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.release>21</maven.compiler.release>

        <!-- Dependency versions -->
        <javafx.version>21.0.2</javafx.version>
        <junit.version>5.10.2</junit.version>

        <!-- Plugin versions -->
        <plugin.compiler.version>3.13.0</plugin.compiler.version>
        <plugin.surefire.version>3.2.5</plugin.surefire.version>
        <plugin.javafx.version>0.0.8</plugin.javafx.version>
        <plugin.exec.version>3.2.0</plugin.exec.version>
    </properties>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- Dependencies                                                          -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->

    <dependencies>

        <!-- JavaFX controls (Button, ComboBox, TableView, …) -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- JavaFX graphics (Canvas, Scene, Stage, …) -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-graphics</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- JUnit 5 — test scope only, not included in the production build -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- Build                                                                 -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->

    <build>
        <plugins>

            <!-- Java 21 compiler — enables records, sealed classes, pattern matching -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${plugin.compiler.version}</version>
                <configuration>
                    <release>${maven.compiler.release}</release>
                    <!-- Treat all warnings as informational, not errors -->
                    <showWarnings>true</showWarnings>
                    <compilerArgs>
                        <arg>-Xlint:all</arg>
                        <arg>-Xlint:-processing</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!--
                Surefire — runs JUnit 5 tests via `mvn test`.
                Tests are discovered automatically by the JUnit Platform.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${plugin.surefire.version}</version>
                <configuration>
                    <includes>
                        <include>**/*Test.java</include>
                    </includes>
                    <!-- Required for JUnit 5 on Java 21 -->
                    <argLine>
                        --add-opens java.base/java.lang=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>

            <!--
                JavaFX Maven Plugin — launches the application.
                Usage:  mvn javafx:run
            -->
            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>${plugin.javafx.version}</version>
                <configuration>
                    <mainClass>ui.TspApp</mainClass>
                    <!-- Pass JVM options required by JavaFX on Java 21 -->
                    <options>
                        <option>--add-opens</option>
                        <option>javafx.graphics/com.sun.javafx.application=ALL-UNNAMED</option>
                    </options>
                </configuration>
            </plugin>

            <!--
                Exec Plugin — runs standalone entry points without JavaFX launcher.
                Usage:  mvn exec:java -Dexec.mainClass="benchmark.SolverBenchmark"
                        mvn exec:java -Dexec.mainClass="tools.FetchPlacesData"
            -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>${plugin.exec.version}</version>
            </plugin>

        </plugins>
    </build>

</project>
